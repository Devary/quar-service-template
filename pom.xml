<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <artifactId>service-template</artifactId>
    <version>1.1.1-SNAPSHOT</version>
    <packaging>jar</packaging>

    <parent>
        <groupId>com.devary</groupId>
        <artifactId>parent</artifactId>
        <version>1.0.10</version>
    </parent>

    <properties>
        <jfrog.base.url>http://192.168.178.41:30990/artifactory</jfrog.base.url>
    </properties>

    <repositories>
        <repository>
            <id>jfrog-virtual</id>
            <name>JFrog Virtual Maven Repo</name>
            <url>${jfrog.base.url}/dev-mvn-repo</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </repository>
    </repositories>

    <pluginRepositories>
        <pluginRepository>
            <id>jfrog-virtual</id>
            <name>JFrog Virtual Maven Plugins</name>
            <url>${jfrog.base.url}/dev-mvn-repo</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </pluginRepository>
    </pluginRepositories>

    <profiles>
        <profile>
            <id>with-database</id>
        </profile>
        <profile>
            <id>local</id>
        </profile>
        <profile>
            <id>prod</id>
        </profile>
        <profile>
            <id>native</id>
        </profile>
    </profiles>
</project>
