<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <artifactId>service-template</artifactId>
    <version>1.0.0-SNAPSHOT</version>

    <parent>
        <groupId>com.devary</groupId>
        <artifactId>parent</artifactId>
        <version>1.0.0</version>
        <relativePath/>
    </parent>

    <properties>
        <jfrog.base.url>http://192.168.178.41:30990/artifactory</jfrog.base.url>
    </properties>

    <repositories>
        <repository>
            <id>jfrog-releases</id>
            <name>JFrog Releases</name>
            <url>${jfrog.base.url}/dev-mvn-repo</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </repository>
    </repositories>

    <pluginRepositories>
        <pluginRepository>
            <id>jfrog-plugins</id>
            <name>JFrog Plugins</name>
            <url>${jfrog.base.url}/dev-mvn-repo</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </pluginRepository>
    </pluginRepositories>

    <profiles>
        <profile>
            <id>local</id>
        </profile>
        <profile>
            <id>native</id>
        </profile>
        <profile>
            <id>use-jfrog</id>
            <distributionManagement>
                <repository>
                    <id>jfrog-releases</id>
                    <name>JFrog Releases</name>
                    <url>${jfrog.base.url}/dev-mvn-repo</url>
                </repository>
                <snapshotRepository>
                    <id>jfrog-snapshots</id>
                    <name>JFrog Snapshots</name>
                    <url>${jfrog.base.url}/dev-mvn-repo</url>
                </snapshotRepository>
            </distributionManagement>
        </profile>
    </profiles>
</project>
